# AI Configuration
OPENAI_KEY=your_openai_key

# Tesseract OCR path
TESSERACT_PATH=your_tesseract_path

# Email Notification Settings
EMAIL=your_email

# OCR Settings
ANTIALIAS_METHOD=LANCZOS

# Bot Mode: PC or ADB
# PC = run directly on Windows with PyAutoGUI
# ADB = run on Boxphone / Emulator via ADB
MODE=ADB

# ADB Configuration
ADB_DEVICE=127.0.0.1:5555
